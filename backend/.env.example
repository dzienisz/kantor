# Skopiuj do .env i dostosuj.
DATABASE_URL=sqlite:///./kantor.db
# DATABASE_URL=postgresql+psycopg://kantor:kantor@localhost:5432/kantor

# Wygeneruj np.: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=720

ADMIN_USERNAME=admin
